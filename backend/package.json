{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc",
    "format:code": "eslint \"{src,test}/**/*.{ts,tsx}\" --fix",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:sync": "npm run typeorm -- migration:generate src/migrations/init -d src/dataSource.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/dataSource.ts",
    "migration:rollback": "npm run typeorm -- migration:revert -d src/dataSource.ts",
    "test": "jest --runInBand --forceExit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^30.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "timekeeper": "^2.3.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  },
  "dependencies": {
    "@faker-js/faker": "^7.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lodash": "^4.18.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "typedi": "^0.10.0",
    "typeorm": "^0.3.28",
    "uuid": "^8.3.2",
    "zod": "^4.3.6"
  }
}
