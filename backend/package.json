  "scripts": {
    "format:code": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "start": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:sync": "npm run typeorm -- migration:generate src/migrations/init -d src/dataSource.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/dataSource.ts",
    "migration:rollback": "npm run typeorm -- migration:revert -d src/dataSource.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
